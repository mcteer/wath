# Copy to deploy/.env and fill in secrets (deploy/.env is gitignored)
WATH_PORT=8080

# MCP endpoint for consumer .cursor/mcp.json and cloud agents (dev: wath-core on localhost)
WATH_MCP_URL=http://127.0.0.1:8080/mcp

# Required for live cloud-agent launch (demo-live-launch.sh, demo-run.sh --launch)
CURSOR_API_KEY=

# GitHub repo URL the cloud agent pushes to (fork of orders-api demo recommended)
WATH_CONSUMER_REPO_URL=https://github.com/YOUR_ORG/orders-api

# Optional: require Bearer token on REST/MCP (required for Cursor HTTP MCP — bypasses broken OAuth flow)
WATH_TOKEN=dev-local-token

WATH_MODEL=composer-2.5

# Consumer discovery for zero-arg wath.onboard (default: consumers/ mounts only)
WATH_CONSUMER_SEARCH_PATHS=consumers
